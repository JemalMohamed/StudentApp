<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.VIBRATE" />

    <application
        android:name=".StudentApplication"
        android:allowBackup="true"
        android:icon="@drawable/ic_launcher_simple"
        android:label="@string/app_name"
        android:roundIcon="@drawable/ic_launcher_simple"
        android:supportsRtl="true"
        android:theme="@style/Theme.StudentApp">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.StudentApp">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity android:name=".ui.courses.CoursesActivity" android:exported="false" />
        <activity android:name=".ui.timetable.TimetableActivity" android:exported="false" />
        <activity android:name=".ui.assignments.AssignmentsActivity" android:exported="false" />
        <activity android:name=".ui.notes.NotesActivity" android:exported="false" />
        <activity android:name=".ui.grades.GradesActivity" android:exported="false" />
        <activity android:name=".ui.timer.TimerActivity" android:exported="false" />
        <activity android:name=".ui.reminders.RemindersActivity" android:exported="false" />

        <receiver
            android:name=".reminder.ReminderReceiver"
            android:exported="false" />

        <receiver
            android:name=".reminder.BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>
    </application>
</manifest>
